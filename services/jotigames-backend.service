[Unit]
Description=JotiGames Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/jotigames.nl/backend
Environment=APP_ENV=production
ExecStart=/var/www/jotigames.nl/backend/.venv/bin/python /var/www/jotigames.nl/backend/run.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
